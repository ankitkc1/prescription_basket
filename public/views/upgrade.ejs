<%- include('partials/head') %>
<%- include('partials/nav') %>
<%- include('partials/flash') %>

<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="premium-panel p-4 p-lg-5 text-center">
        <span class="eyebrow">Premium feature</span>
        <h1 class="fw-bold mt-2">Checkout is available on Premium</h1>
        <p class="lead text-muted">Your basket is ready, but one-tap checkout is a premium demo feature. Upgrade to unlock the checkout screen, smart weekly repeats and advanced store sorting.</p>

        <div class="premium-price my-4">
          <span>$4.99</span>
          <small>/ month demo</small>
        </div>

        <div class="row g-3 text-start mb-4">
          <div class="col-md-4"><div class="premium-feature">One-tap checkout demo</div></div>
          <div class="col-md-4"><div class="premium-feature">Smarter store sorting</div></div>
          <div class="col-md-4"><div class="premium-feature">Weekly repeat baskets</div></div>
        </div>

        <form method="POST" action="/upgrade" class="d-inline-block">
          <input type="hidden" name="returnTo" value="/checkout/<%= basket._id %>">
          <button class="btn btn-primary-brand btn-lg rounded-pill px-5" type="submit">Upgrade demo account</button>
        </form>
        <a href="/basket/<%= basket._id %>" class="btn btn-outline-dark btn-lg rounded-pill px-4 ms-md-2 mt-3 mt-md-0">Back to basket</a>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
