<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<%- include('../partials/flash') %>

<main class="auth-wrap py-5">
  <div class="container">
    <div class="auth-card mx-auto">
      <span class="eyebrow">Welcome back</span>
      <h1 class="h2 fw-bold mb-3">Log in to your basket</h1>
      <p class="text-muted">Continue your weekly grocery planning.</p>
      <form method="POST" action="/login" class="mt-4">
        <div class="mb-3">
          <label class="form-label">Email</label>
          <input name="email" type="email" class="form-control form-control-lg" required>
        </div>
        <div class="mb-4">
          <label class="form-label">Password</label>
          <input name="password" type="password" class="form-control form-control-lg" required>
        </div>
        <button class="btn btn-primary-brand btn-lg w-100 rounded-pill" type="submit">Log in</button>
      </form>
      <p class="text-center mt-4 mb-0">New here? <a href="/register">Create an account</a></p>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
