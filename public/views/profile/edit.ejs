<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<%- include('../partials/flash') %>

<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-9">
      <div class="page-panel p-4 p-lg-5">
        <span class="eyebrow">Food profile</span>
        <h1 class="fw-bold mt-2 mb-3">Personalise your grocery recommendations</h1>
        <p class="text-muted">This profile helps the app create a basket that feels realistic, culturally suitable and budget-aware.</p>

        <form method="POST" action="/profile" class="mt-4">
          <div class="row g-4">
            <div class="col-md-6">
              <label class="form-label">Weekly budget ($AUD)</label>
              <input type="number" min="30" max="300" step="1" name="weeklyBudget" class="form-control form-control-lg" value="<%= user.profile.weeklyBudget %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Suburb</label>
              <input name="suburb" class="form-control form-control-lg" value="<%= user.profile.suburb %>" placeholder="Melbourne CBD">
            </div>
            <div class="col-md-6">
              <label class="form-label">Cultural food preference</label>
              <select name="culturalPreference" class="form-select form-select-lg">
                <% culturalOptions.forEach((option) => { %>
                  <option value="<%= option %>" <%= user.profile.culturalPreference === option ? 'selected' : '' %>><%= option %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Diet</label>
              <select name="diet" class="form-select form-select-lg">
                <% dietOptions.forEach((option) => { %>
                  <option value="<%= option %>" <%= user.profile.diet === option ? 'selected' : '' %>><%= option %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Cooking time</label>
              <select name="cookingTime" class="form-select form-select-lg">
                <% cookingTimeOptions.forEach((option) => { %>
                  <option value="<%= option %>" <%= user.profile.cookingTime === option ? 'selected' : '' %>><%= option %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Ingredients to avoid</label>
              <input name="avoidIngredients" class="form-control form-control-lg" value="<%= user.profile.avoidIngredients.join(', ') %>" placeholder="e.g. nuts, lactose">
              <div class="form-text">Use commas to separate items.</div>
            </div>
          </div>

          <div class="mt-4">
            <label class="form-label">Health goals</label>
            <div class="chip-grid">
              <% healthGoalOptions.forEach((option) => { %>
                <label class="choice-chip">
                  <input type="checkbox" name="healthGoals" value="<%= option %>" <%= user.profile.healthGoals.includes(option) ? 'checked' : '' %>>
                  <span><%= option %></span>
                </label>
              <% }) %>
            </div>
          </div>

          <div class="mt-4">
            <label class="form-label">Health conditions</label>
            <div class="chip-grid">
              <% healthConditionOptions.forEach((option) => { %>
                <label class="choice-chip">
                  <input type="checkbox" name="healthConditions" value="<%= option %>" <%= user.profile.healthConditions.includes(option) ? 'checked' : '' %>>
                  <span><%= option %></span>
                </label>
              <% }) %>
            </div>
            <p class="small text-muted mt-2 mb-0">This prototype offers general grocery guidance only. It is not medical advice.</p>
          </div>

          <div class="d-flex gap-3 mt-5">
            <button class="btn btn-primary-brand btn-lg rounded-pill px-4" type="submit">Save profile</button>
            <a href="/dashboard" class="btn btn-outline-dark btn-lg rounded-pill px-4">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
